# 观星问易 · 环境变量示例
# 复制为 .env：cp .env.example .env
# docker-compose 与后端 application.yml 都读取这些变量（后端通过环境变量覆盖默认值）

# ===== PostgreSQL =====
POSTGRES_DB=guanxing_wenyi
POSTGRES_USER=gxwy
POSTGRES_PASSWORD=gxwy_dev_pwd
POSTGRES_PORT=5432

# ===== Redis =====
# 若本机 6379 已被占用（如 WSL 里的 Redis），换个端口并同步 SPRING_DATA_REDIS_PORT，
# 否则容器端口发布会静默失败、应用连到别的 Redis 上
REDIS_PORT=6379

# ===== 后端（Spring Boot 读取，留默认即可本地联调）=====
# 数据源（注意 stringtype=unspecified，便于 String ↔ jsonb 绑定）
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/guanxing_wenyi?stringtype=unspecified
SPRING_DATASOURCE_USERNAME=gxwy
SPRING_DATASOURCE_PASSWORD=gxwy_dev_pwd
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# AI 提供方：mock（默认，无外部依赖）| llm（真实模型，失败自动回退 mock）
GXWY_AI_PROVIDER=mock
# provider=llm 时选择厂商：doubao | deepseek(预留)
GXWY_AI_CLIENT=doubao
# 真实模型的 API Key —— 只填到 .env(已 gitignore)，本示例文件被 git 跟踪，绝不能填真实值！
# 豆包（火山方舟）：https://console.volcengine.com/ark 申请
DOUBAO_API_KEY=
# 模型名或推理接入点 ep-xxx，不填用默认 doubao-seed-1-6-250615
# DOUBAO_MODEL=
# 模型读超时毫秒（默认 6000；慢模型如 seed-2-1-turbo 建议 7000，前端总预算 8s）
# GXWY_AI_TIMEOUT_MS=7000
# DeepSeek（预留）：https://platform.deepseek.com 申请
# DEEPSEEK_API_KEY=

# 语音提供方（第一阶段固定 mock；预留切真实 STT）
GXWY_VOICE_PROVIDER=mock

# 允许跨域的前端地址
GXWY_CORS_ALLOWED_ORIGINS=http://localhost:3000
